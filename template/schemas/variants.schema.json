{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["variants"],
  "properties": {
    "variant_axes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key"],
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "label": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "value_type": { "type": "string", "enum": ["string", "number", "boolean"] },
          "unit": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sku_id",
          "media_refs"
        ],
        "properties": {
          "sku_id": { "type": "string", "minLength": 1 },
          "variant_id": { "type": "string", "minLength": 1 },
          "parent_product_id": { "type": "string", "minLength": 1 },
          "model_number": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "identifiers": { "type": "object" },
          "options": { "type": "object" },
          "attributes": { "type": "object" },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "evidence": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "package": { "type": "object" },
          "media_refs": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
